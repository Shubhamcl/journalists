{{!< default}}

<main class="site-main">
    <div class="container">
        {{#get "posts" filter="featured:true" include="tags,authors" limit="1" as |featured_posts|}}
            {{#if featured_posts}}
                {{#foreach featured_posts}}
                    {{> "hero-post"}}
                {{/foreach}}
            {{else}}
                {{#foreach ../posts limit="1"}}
                    {{> "hero-post"}}
                {{/foreach}}
            {{/if}}
        {{/get}}

        <div class="rule rule-heavy"></div>

        <section class="editorial-grid" aria-label="Latest stories">
            <div class="column column-bordered-right">
                {{#foreach posts from="2" to="3"}}
                    {{> "post-card" card_class="stacked" title_size="small"}}
                {{/foreach}}
            </div>

            <div class="column column-bordered-right">
                {{#foreach posts from="4" to="4"}}
                    {{> "post-card" card_class="lead" title_size="large"}}
                {{else}}
                    {{#foreach posts from="2" to="2"}}
                        {{> "post-card" card_class="lead" title_size="large"}}
                    {{/foreach}}
                {{/foreach}}
            </div>

            <aside class="column index-column" aria-label="The Index">
                <h2 class="index-title">The<br>Index</h2>
                {{#foreach posts from="2" to="6"}}
                    <article class="index-item">
                        <span class="index-number" aria-hidden="true"></span>
                        <div>
                            <h3><a href="{{url}}">{{title}}</a></h3>
                            <p>{{#if primary_tag}}{{primary_tag.name}}{{else}}Latest{{/if}}</p>
                        </div>
                    </article>
                {{/foreach}}
            </aside>
        </section>

        {{#match @custom.dark_feature_band true}}
            {{#foreach posts from="5" to="5"}}
                <section class="feature-band">
                    <div class="feature-band-content">
                        <p class="eyebrow">{{#if primary_tag}}{{primary_tag.name}}{{else}}Feature{{/if}}</p>
                        <h2><a href="{{url}}">{{title}}</a></h2>
                        {{#if excerpt}}<p>{{excerpt words="32"}}</p>{{/if}}
                        <a class="text-link inverted" href="{{url}}">Read the story</a>
                    </div>
                    {{#if feature_image}}
                        <a class="feature-band-image" href="{{url}}" aria-label="{{title}}">
                            {{> "responsive-image" image_class="feature-image"}}
                        </a>
                    {{/if}}
                </section>
            {{/foreach}}
        {{/match}}

        {{#get "posts" filter="tag:ai" include="tags,authors" limit="4" as |ai_posts|}}
            {{#match ai_posts.length ">" 0}}
                <section class="topic-section">
                    <div class="section-heading">
                        <h2>AI</h2>
                        <a class="text-link" href="/tag/ai/">More AI</a>
                    </div>
                    <div class="topic-grid">
                        {{#foreach ai_posts}}
                            {{> "post-card" card_class="topic-card" title_size="small"}}
                        {{/foreach}}
                    </div>
                </section>
            {{/match}}
        {{/get}}

        {{#get "posts" filter="tag:apps" include="tags,authors" limit="4" as |apps_posts|}}
