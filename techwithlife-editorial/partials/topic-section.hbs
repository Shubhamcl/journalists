{{#get "posts" filter="tag:{{tag_slug}}" include="tags,authors" limit="4" as |topic_posts|}}
    {{#match topic_posts.length ">" 0}}
        <section class="topic-section">
            <div class="section-heading">
                <h2>{{section_title}}</h2>
                <a class="text-link" href="/tag/{{tag_slug}}/">More {{section_title}}</a>
            </div>
            <div class="topic-grid">
                {{#foreach topic_posts}}
                    {{> "post-card" card_class="topic-card" title_size="small"}}
                {{/foreach}}
            </div>
        </section>
    {{/match}}
{{/get}}
