{{#get "posts" filter="id:-{{id}}" include="tags,authors" limit="3" as |related_posts|}}
    {{#match related_posts.length ">" 0}}
        <section class="read-next container">
            <div class="section-heading">
                <h2>Read next</h2>
            </div>
            <div class="topic-grid">
                {{#foreach related_posts}}
                    {{> "post-card" card_class="topic-card" title_size="small"}}
                {{/foreach}}
            </div>
        </section>
    {{/match}}
{{/get}}
